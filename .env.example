# Copy to .env and fill in. NEVER commit .env
# Create key at: https://app.fireworks.ai/settings/users/api-keys
FIREWORKS_API_KEY=fw-xxxxxxxxxxxxxxxx

# Default model (verified via scripts/smoke_test.py)
FIREWORKS_MODEL=accounts/fireworks/models/gemma-3-27b-it

# Optional: self-hosted vLLM endpoint on AMD MI300X (AMD Developer Cloud droplet)
# AMD_VLLM_BASE_URL=http://<droplet-ip>:8000/v1
# AMD_VLLM_MODEL=google/gemma-3-27b-it
