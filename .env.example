# FourCast — local development environment
# Copy to .env and fill in. NEVER commit .env (it is git-ignored).
# Create a key at: https://app.fireworks.ai/settings/users/api-keys
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxx

# --- Optional model overrides (defaults live in agent/fw.py) ---
# Vision / perceiver (writes the grounded Scene Report):
# T2_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
# Stylist (writes the 3 candidate captions per style):
# T2_STYLIST_MODEL=accounts/fireworks/models/glm-5p2
# Judge (scores accuracy + style, picks the winner — different model family):
# T2_JUDGE_MODEL=accounts/fireworks/models/gpt-oss-120b

# --- Gemma bonus path (opt-in) ---
# Route the stylist through Gemma on Fireworks to compete for the
# "Best Use of Gemma in Video Captioning" prize. GLM 5.2 stays the fallback.
# T2_USE_GEMMA=1
# T2_GEMMA_MODEL=accounts/fireworks/models/gemma-4-31b-it

# --- Runtime knobs (defaults are harness-safe) ---
# T2_BUDGET_S=510          # global soft deadline in seconds (harness cap is 600)
# T2_CLIP_CONCURRENCY=4    # clips processed in flight
# T2_CLIP_TIMEOUT_S=180    # per-clip hard cap -> grounded fallback (never a zero)
# T2_FAST=1                # skip the refine round for lowest latency
# SKIP_API=1               # offline mode: full harness contract, zero API spend (CI uses this)
